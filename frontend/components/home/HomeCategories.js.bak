  { name: "Bikes", icon: "🏍️", href: "/search?category=bike" },
  { name: "Trucks", icon: "🚚", href: "/search?category=truck" },
  { name: "Buses", icon: "🚌", href: "/search?category=bus" },
  { name: "Tractors", icon: "🚜", href: "/search?category=tractor" },
  { name: "Spare Parts", icon: "⚙️", href: "/search?category=parts" },
  { name: "Machinery", icon: "🏗️", href: "/search?category=machinery" },
  { name: "Showrooms", icon: "🏢", href: "/search?category=showroom" },
  { name: "Tyres", icon: "🛞", href: "/search?category=tyres" },
