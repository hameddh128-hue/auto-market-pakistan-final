# Copy this file to .env.local for local dev, and add the same keys under
# Vercel > Project Settings > Environment Variables for production.
# Find all three values in: Supabase Dashboard > Project Settings > API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (no NEXT_PUBLIC_ prefix — never exposed to the browser).
# Used exclusively by pages/api/admin/delete-user.js to delete a user's
# Supabase Auth account. Find it under Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_SITE_URL=http://localhost:3000
